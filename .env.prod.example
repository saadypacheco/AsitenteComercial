# ── Producción · variables del docker-compose.prod.yml ──────────────────────
# Copiá a  .env  en la raíz del repo (en el VPS) y completá. NO se commitea.
# Estas las usa el COMPOSE (substitución ${...} en labels y build args).

# Dominio raíz del proyecto (sin https://). El front queda en https://<DOMAIN>
# y la API en https://api.<DOMAIN>. Apuntá los DNS A de @ , www y api al VPS.
DOMAIN=mentorcomercial.ejemplo.com

# Clave de la API del bridge WAHA (inventá una fuerte). Debe coincidir con
# WAHA_API_KEY de backend/.env (el backend la usa para hablarle a WAHA).
WAHA_API_KEY=

# Claves PÚBLICAS de Supabase (se inyectan al build del frontend). Si el front
# no usa Supabase directo, podés dejarlas vacías.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
