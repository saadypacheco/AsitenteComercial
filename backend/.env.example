# backend/.env  —  copiar a .env y completar. NUNCA commitear .env real.
ENVIRONMENT=development

# Supabase self-hosted (Postgres + Auth + Storage)
SUPABASE_URL=http://localhost:8000
SUPABASE_SERVICE_ROLE_KEY=          # service_role — SOLO backend, jamás al frontend
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Bridge WhatsApp (WAHA) — red privada
WAHA_BASE_URL=http://waha:3000
WAHA_API_KEY=
WEBHOOK_SECRET=                     # HMAC para validar el webhook entrante

# IA — Gemini por defecto vía LiteLLM (cambiable: openai/gpt-4o, anthropic/claude-...)
LLM_MODEL=gemini/gemini-2.0-flash
GEMINI_API_KEY=

# Telegram — asistente conversacional (bot creado en @BotFather)
TELEGRAM_BOT_TOKEN=            # token del bot (ej: 1234567890:ABCdef...)
TELEGRAM_OWNER_CHAT_ID=        # chat_id de Cecilia — el bot lo informa al primer mensaje si no está seteado

# Transcripción self-hosted (multi-idioma)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu

STORAGE_BUCKET=wa-media
