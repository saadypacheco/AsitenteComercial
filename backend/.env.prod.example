# ── Producción · variables del backend + worker ────────────────────────────
# Copiá a  backend/.env  en el VPS y completá. NO se commitea (tiene secretos).

ENVIRONMENT=production

# ── Base de datos: Supabase Cloud ───────────────────────────────────────────
# Project Settings → Database → Connection string (URI). Usá el pooler (puerto
# 6543, "Session"/"Transaction") o la conexión directa (5432). Incluye la pass.
# Ej: postgresql://postgres.<ref>:<PASSWORD>@aws-0-xx.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ── Auth (JWT propia) ───────────────────────────────────────────────────────
JWT_SECRET=                      # generá una aleatoria larga: openssl rand -hex 32
FRONTEND_URL=https://mentorcomercial.ejemplo.com   # = https://<DOMAIN> (CORS + magic links)

# Dueña (owner) que se crea en el primer arranque (sin datos demo):
DEFAULT_LIDER_EMAIL=cecilia@tudominio.com
DEFAULT_LIDER_PASSWORD=          # contraseña real fuerte (cambiá luego del primer login)

# Bootstrap del tenant (primer arranque):
TENANT_NAME=Agencia Cecilia
OBSERVER_SESSION=default         # = nombre de la sesión WAHA = tenants.ia_wa_jid
OWNER_WA_JID=                    # WhatsApp personal de Cecilia para el briefing, ej 549XXXX@c.us (opcional)

# ── Bridge WhatsApp (WAHA) — red interna ────────────────────────────────────
WAHA_BASE_URL=http://mc-waha:3000
WAHA_API_KEY=                    # MISMA que la del .env raíz
WEBHOOK_SECRET=                  # dejar VACÍO por ahora (HMAC sha256: endurecer luego)

# ── IA (opcional) ───────────────────────────────────────────────────────────
LLM_MODEL=gemini/gemini-2.0-flash
GEMINI_API_KEY=                  # vacío = resúmenes deterministas (fallback)

# ── Transcripción (opcional, US3) ───────────────────────────────────────────
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
